{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "resourceGroupName": {
        "value": "${AZURE_RESOURCE_GROUP}"
      },
      "environmentName": {
        "value": "${AZURE_ENV_NAME}"
      },
      "location": {
        "value": "${AZURE_LOCATION=westus2}"
      },
      "aiFoundryResourceName": {
        "value": "${AZURE_AI_ACCOUNT_NAME=}"
      },
      "aiFoundryProjectName": {
        "value": "${AZURE_AI_PROJECT_NAME=hermes-build}"
      },
      "aiDeploymentsLocation": {
        "value": "${AZURE_LOCATION=westus2}"
      },
      "principalId": {
        "value": "${AZURE_PRINCIPAL_ID}"
      },
      "principalType": {
        "value": "${AZURE_PRINCIPAL_TYPE}"
      },
      "aiProjectDeploymentsJson": {
        "value": "${AI_PROJECT_DEPLOYMENTS=[]}"
      },
      "foundryModelDeploymentName": {
        "value": "${AZURE_FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-5.4}"
      },
      "foundryModelName": {
        "value": "${AZURE_FOUNDRY_MODEL_NAME=gpt-5.4}"
      },
      "foundryModelVersion": {
        "value": "${AZURE_FOUNDRY_MODEL_VERSION=2026-03-05}"
      },
      "foundryModelSkuName": {
        "value": "${AZURE_FOUNDRY_MODEL_SKU_NAME=DataZoneStandard}"
      },
      "foundryModelSkuCapacity": {
        "value": "${AZURE_FOUNDRY_MODEL_SKU_CAPACITY=100}"
      },
      "foundryAuxModelDeploymentName": {
        "value": "${AZURE_FOUNDRY_AUX_MODEL_DEPLOYMENT_NAME=gpt-5.4-mini}"
      },
      "foundryAuxModelName": {
        "value": "${AZURE_FOUNDRY_AUX_MODEL_NAME=gpt-5.4-mini}"
      },
      "foundryAuxModelVersion": {
        "value": "${AZURE_FOUNDRY_AUX_MODEL_VERSION=2026-03-17}"
      },
      "foundryAuxModelSkuName": {
        "value": "${AZURE_FOUNDRY_AUX_MODEL_SKU_NAME=DataZoneStandard}"
      },
      "foundryAuxModelSkuCapacity": {
        "value": "${AZURE_FOUNDRY_AUX_MODEL_SKU_CAPACITY=50}"
      },
      "foundryModelApiMode": {
        "value": "${AZURE_FOUNDRY_MODEL_API_MODE=chat_completions}"
      },
      "foundryModelAuthMode": {
        "value": "${AZURE_FOUNDRY_AUTH_MODE=entra_id}"
      },
      "aiProjectConnectionsJson": {
        "value": "${AI_PROJECT_CONNECTIONS=[]}"
      },
      "externalModelBaseUrl": {
        "value": "${AZURE_FOUNDRY_EXTERNAL_BASE_URL=}"
      },
      "externalModelAccountResourceId": {
        "value": "${AZURE_FOUNDRY_EXTERNAL_ACCOUNT_ID=}"
      },
      "externalModelDeploymentName": {
        "value": "${AZURE_FOUNDRY_EXTERNAL_MODEL_DEPLOYMENT_NAME=}"
      },
      "externalModelAuxDeploymentName": {
        "value": "${AZURE_FOUNDRY_EXTERNAL_AUX_DEPLOYMENT_NAME=}"
      },
      "aiProjectConnectionCredentialsJson": {
        "value": "${AI_PROJECT_CONNECTION_CREDENTIALS=}"
      },
      "aiProjectDependentResourcesJson": {
        "value": "${AI_PROJECT_DEPENDENT_RESOURCES=[]}"
      },
      "enableHostedAgents": {
        "value": "${ENABLE_HOSTED_AGENTS=true}"
      },
      "useExistingAiProject": {
        "value": "${USE_EXISTING_AI_PROJECT=false}"
      },
      "existingContainerRegistryResourceId": {
        "value": "${AZURE_CONTAINER_REGISTRY_RESOURCE_ID=}"
      },
      "existingContainerRegistryEndpoint": {
        "value": "${AZURE_CONTAINER_REGISTRY_ENDPOINT=}"
      },
      "existingAcrConnectionName": {
        "value": "${AZURE_AI_PROJECT_ACR_CONNECTION_NAME=}"
      }
    }
}
